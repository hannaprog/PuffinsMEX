  float Kp;
  float Ki;
  float Kd;
};
const PidGains GAINS_THRUSTER = {1.0, 2.0, 3.0};

// Buoyancy is slower and delayed. Start gentle to avoid overshoot.
const PidGains GAINS_BUOYANCY = {1.0, 2.0, 3.0};

float Kp = GAINS_THRUSTER.Kp;
